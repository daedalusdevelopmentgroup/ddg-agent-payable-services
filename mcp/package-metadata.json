{
  "name": "@daedalusdevelopmentgroup/ddg-agent-services-mcp",
  "version": "0.1.0",
  "title": "DDG Agent-Payable Services MCP",
  "description": "Payment-aware MCP wrapper for DDG Agent-Payable Services: discovery resources, status, checkout conformance, free safety scan, order polling, and paid-service 402 challenges.",
  "homepage": "https://agents.daedalusdevelopmentgroup.com/.well-known/ai",
  "documentation": "https://agents.daedalusdevelopmentgroup.com/.well-known/ddg-agent-swarm-mcp-design.md",
  "base_url": "https://agents.daedalusdevelopmentgroup.com",
  "transport": {
    "stdio": {
      "command": "uvx",
      "args": ["ddg-agent-services-mcp"],
      "required_env": ["DDG_MCP_AGENT_ID"],
      "optional_env": ["DDG_AGENT_SERVICES_BASE_URL", "DDG_AGENT_SERVICES_ALLOWED_HOSTS"]
    },
    "http_streamable": {
      "status": "source_ready_local_smoked_public_deploy_pending",
      "local_url": "http://127.0.0.1:8891/mcp",
      "planned_public_url": "https://mcp.daedalusdevelopmentgroup.com/mcp",
      "hosted_client_requirement": "pass stable agent_id tool argument for paid/order-scoped calls"
    }
  },
  "tools": [
    "ddg_mcp_security_profile",
    "ddg_public_resource_index",
    "ddg_fetch_public_resource",
    "ddg_list_services",
    "ddg_agent_status",
    "ddg_checkout_conformance",
    "ddg_list_models",
    "ddg_list_local_runtime_options",
    "ddg_skill_safety_scan",
    "ddg_security_service_catalog",
    "ddg_order_status",
    "ddg_order_artifact",
    "ddg_receipt_verify_design",
    "ddg_tx_smoke_test",
    "ddg_quote_payment",
    "ddg_submit_order",
    "ddg_run_paid_model",
    "ddg_request_ollama_model"
  ],
  "resources": [
    "ddg://manifest/ai",
    "ddg://manifest/status",
    "ddg://manifest/catalog",
    "ddg://manifest/pricing",
    "ddg://manifest/checkout-conformance",
    "ddg://manifest/cybersecurity-services",
    "ddg://docs/llms",
    "ddg://docs/mcp-design",
    "ddg://openapi"
  ],
  "payment_protocols_current_public_live": ["x402", "direct_crypto_auto"],
  "payment_protocols_pending": ["mpp"],
  "security": {
    "no_arbitrary_shell": true,
    "no_file_write_tools": true,
    "no_provider_credential_relay": true,
    "paid_tools_return_structured_402": true,
    "authorization_forwarding": "Payment scheme only",
    "response_header_allowlist": true,
    "response_body_redaction": true,
    "response_size_cap_bytes": 786432,
    "hosted_remote_requires_agent_id_argument": true,
    "resource_allowlist_only": true
  },
  "submission_status": "stdio_package_ready_registry_submission_waits_for_public_package_or_hosted_transport"
}
